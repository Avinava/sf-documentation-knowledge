{
  "name": "@sfdxy/sf-documentation-knowledge",
  "version": "1.2.0",
  "description": "Salesforce documentation knowledge system — collect, process, and serve SF docs for LLM agents via MCP + Context Engineering",
  "type": "module",
  "main": "./dist/mcp/server.js",
  "types": "./dist/mcp/server.d.ts",
  "bin": {
    "sf-knowledge": "./dist/cli/generate.js"
  },
  "exports": {
    ".": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./graph-query": {
      "types": "./dist/utils/graph-query.d.ts",
      "import": "./dist/utils/graph-query.js"
    }
  },
  "files": [
    "dist",
    "knowledge/current",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "collect": "node dist/cli/collect.js",
    "process": "node dist/cli/process.js",
    "generate": "node dist/cli/generate.js",
    "discover": "node dist/cli/discover.js",
    "graph:stats": "node dist/cli/graph-stats.js",
    "mcp:dev": "node dist/mcp/server.js",
    "mcp:start": "node dist/mcp/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "salesforce",
    "documentation",
    "mcp",
    "knowledge-graph",
    "context-engineering",
    "llm",
    "ai-agent",
    "apex",
    "sfdc"
  ],
  "author": "Avinava",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avinava/sf-documentation-knowledge"
  },
  "bugs": {
    "url": "https://github.com/Avinava/sf-documentation-knowledge/issues"
  },
  "homepage": "https://github.com/Avinava/sf-documentation-knowledge#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-metrics": "^2.1.0",
    "jsdom": "^25.0.0",
    "p-limit": "^7.3.0",
    "pino": "^9.0.0",
    "puppeteer": "^24.39.0",
    "turndown": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  }
}
